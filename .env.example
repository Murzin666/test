# Скопируйте этот файл в .env и заполните реальными значениями.
# .env НЕ должен попадать в git (см. .gitignore) и никогда не передаётся на фронтенд.

# Публичный адрес ВАШЕГО сервера (например, выданный Railway) — без слэша на конце.
PUBLIC_BASE_URL=https://ваш-проект.up.railway.app

# Домены, которым разрешено обращаться к серверу, через запятую (не критично
# для схемы через Универсальную платёжную систему Tilda, но не помешает).
ALLOWED_ORIGINS=http://localhost:8000

# Ключ для защищённых операций (возврат/отмена/статус) — придумайте длинную
# случайную строку, например: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=CHANGE_ME_TOO

# Путь к файлу базы данных SQLite. На Railway ОБЯЗАТЕЛЬНО должен указывать
# на смонтированный Volume (например, /data/tenants.db) — иначе все точки
# и заказы пропадут при следующем деплое.
DB_PATH=./tenants.db

# Ключ шифрования чувствительных полей (пароль банка, секрет Tilda) в БД.
# Сгенерировать: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Потеряете этот ключ — расшифровать сохранённые данные будет невозможно.
ENCRYPTION_KEY=

# Настройки самих торговых точек (логины банка, секреты Tilda и т.п.)
# сюда больше не входят — они хранятся в БД и добавляются командой:
#   python3 manage_tenants.py add shop1 --bank-login ... --bank-password ... ...
# См. tilda-integration/multi-tenant.md
